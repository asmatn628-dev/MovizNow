rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "asmatn628@gmail.com" && request.auth.token.email_verified == true) ||
          (request.auth.token.email == "asmatullah9327@gmail.com" && request.auth.token.email_verified == true)
        );
    }

    function isDataEditor() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'data_editor';
    }

    function isAdminOrEditor() {
      return isAdmin() || isDataEditor();
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.uid == request.auth.uid;
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.status == resource.data.status);
      allow delete: if isAdmin();
    }

    match /genres/{genreId} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrEditor();
    }

    match /languages/{languageId} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrEditor();
    }

    match /qualities/{qualityId} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrEditor();
    }

    match /content/{contentId} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrEditor();
    }

    match /analytics/{eventId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /income/{incomeId} {
      allow read, write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
