rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "asmatn628@gmail.com" && request.auth.token.email_verified == true) ||
          (request.auth.token.email == "asmatullah9327@gmail.com" && request.auth.token.email_verified == true) ||
          (request.auth.token.email == "kabirahmaddev@gmail.com" && request.auth.token.email_verified == true)
        );
    }

    function isContentManager() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'content_manager';
    }

    function isUserManager() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'user_manager';
    }

    function isManager() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager';
    }

    function isAdminOrEditor() {
      return isAdmin() || isContentManager() || isManager();
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isManager() || (isUserManager() && (resource.data.managedBy == request.auth.uid || resource.data.status == 'pending'));
      allow create: if (isOwner(userId) && request.resource.data.uid == request.auth.uid && request.resource.data.role == 'user') || 
                       (isOwner(userId) && request.resource.data.uid == request.auth.uid && request.resource.data.role in ['user', 'trial', 'selected_content'] && 'managedBy' in request.resource.data) ||
                       (isOwner(userId) && request.resource.data.uid == request.auth.uid && isAdmin()) ||
                       (isUserManager() && request.resource.data.managedBy == request.auth.uid && request.resource.data.role in ['user', 'trial', 'selected_content'] && request.resource.data.status != 'suspended') ||
                       (isManager() && request.resource.data.managedBy == request.auth.uid && request.resource.data.role in ['user', 'trial', 'selected_content'] && request.resource.data.status != 'suspended');
      allow update: if isAdmin() || 
                       (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.status == resource.data.status) ||
                       (isUserManager() && resource.data.managedBy == request.auth.uid && request.resource.data.managedBy == request.auth.uid && request.resource.data.role in ['user', 'trial', 'selected_content'] && request.resource.data.status != 'suspended') ||
                       (isUserManager() && resource.data.status == 'pending' && request.resource.data.managedBy == request.auth.uid && request.resource.data.role in ['user', 'trial', 'selected_content'] && request.resource.data.status != 'suspended') ||
                       (isManager() && resource.data.managedBy == request.auth.uid && request.resource.data.managedBy == request.auth.uid && request.resource.data.role in ['user', 'trial', 'selected_content'] && request.resource.data.status != 'suspended') ||
                       (isManager() && resource.data.status == 'pending' && request.resource.data.managedBy == request.auth.uid && request.resource.data.role in ['user', 'trial', 'selected_content'] && request.resource.data.status != 'suspended');
      allow delete: if isAdmin();
    }

    match /genres/{genreId} {
      allow read: if true;
      allow write: if isAdminOrEditor();
    }

    match /languages/{languageId} {
      allow read: if true;
      allow write: if isAdminOrEditor();
    }

    match /qualities/{qualityId} {
      allow read: if true;
      allow write: if isAdminOrEditor();
    }

    match /content/{contentId} {
      // Allow read for all authenticated users, or for unauthenticated users if content is published
      allow read: if isAuthenticated() || resource.data.status == 'published';
      allow write: if isAdminOrEditor();
    }

    match /metadata/{docId} {
      allow read: if true;
      allow write: if isAdminOrEditor();
    }

    match /analytics/{eventId} {
      allow read: if isAdmin() || isManager() || (isUserManager() && get(/databases/$(database)/documents/users/$(resource.data.userId)).data.managedBy == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /income/{incomeId} {
      allow read, write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrEditor();
    }

    match /test/{docId} {
      allow read, write: if isAdmin();
    }

    function isValidFCMToken(data) {
      return data.token is string && data.token.size() > 0 &&
             data.userId is string && data.userId.size() > 0 &&
             data.updatedAt is string;
    }

    match /fcm_tokens/{tokenId} {
      allow read: if isAdmin();
      allow create: if (isAuthenticated() && isValidFCMToken(request.resource.data) && request.resource.data.userId == request.auth.uid) ||
                       (!isAuthenticated() && isValidFCMToken(request.resource.data) && request.resource.data.userId == 'anonymous');
      allow update: if (isAuthenticated() && isValidFCMToken(request.resource.data) && request.resource.data.userId == request.auth.uid && (resource.data.userId == request.auth.uid || resource.data.userId == 'anonymous')) ||
                       (!isAuthenticated() && isValidFCMToken(request.resource.data) && request.resource.data.userId == 'anonymous' && resource.data.userId == 'anonymous');
      allow delete: if isAdmin();
    }

    match /movie_requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['requestedBy', 'requestCount']) &&
         request.resource.data.requestedBy.size() == resource.data.requestedBy.size() + 1 &&
         request.auth.uid in request.resource.data.requestedBy &&
         !(request.auth.uid in resource.data.requestedBy))
      );
      allow delete: if isAdmin();
    }

    function isValidReport(data) {
      return data.userId is string && data.userId.size() > 0 &&
             data.userName is string &&
             data.contentId is string &&
             data.contentTitle is string &&
             data.contentType in ['movie', 'series'] &&
             data.linkId is string &&
             data.linkName is string &&
             data.linkUrl is string &&
             data.status in ['pending', 'resolved'] &&
             data.createdAt == request.time;
    }

    match /reported_links/{reportId} {
      allow read: if isAdminOrEditor() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidReport(request.resource.data);
      allow update, delete: if isAdminOrEditor();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

  }
}
